generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  smsConsent      Boolean   @default(false)
  emailConsent    Boolean   @default(false)
  preferredChannel String   @default("sms")
  timezone        String    @default("America/New_York")
  metadata        Json?
  leads           Lead[]
  conversations   Conversation[]
  appointments    Appointment[]
  broker          Broker?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([phone])
  @@index([email])
}

model Lead {
  id               String          @id @default(cuid())
  source           String
  sourceDetails    Json?
  contactId        String
  contact          Contact         @relation(fields: [contactId], references: [id])
  status           String          @default("new")
  qualificationScore Int?
  classification   String?
  assignedAgentId  String?
  conversations    Conversation[]
  appointments     Appointment[]
  escalations     Escalation[]
  tenantApp       TenantApplication?
  firstResponseAt  DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status])
  @@index([classification])
  @@index([createdAt])
  @@index([assignedAgentId])
}

model Conversation {
  id          String     @id @default(cuid())
  leadId      String
  lead        Lead       @relation(fields: [leadId], references: [id])
  contactId   String
  contact     Contact    @relation(fields: [contactId], references: [id])
  messages    Message[]
  status      String     @default("active")
  agentId     String     @default("speed-to-lead")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([leadId])
  @@index([status])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String
  channel        String
  content        String
  metadata       Json?
  timestamp      DateTime     @default(now())

  @@index([conversationId])
  @@index([timestamp])
}

model Appointment {
  id               String    @id @default(cuid())
  leadId           String
  lead             Lead      @relation(fields: [leadId], references: [id])
  contactId        String
  contact          Contact   @relation(fields: [contactId], references: [id])
  agentId          String
  scheduledAt      DateTime
  durationMinutes  Int       @default(30)
  type             String    @default("phone")
  status           String    @default("scheduled")
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([leadId])
  @@index([scheduledAt])
  @@index([status])
}

model Escalation {
  id             String    @id @default(cuid())
  leadId         String
  lead           Lead      @relation(fields: [leadId], references: [id])
  conversationId String
  reason         String
  status         String    @default("pending")
  confidence     Float
  context        String
  assignedTo     String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([leadId])
}

model CommunicationEvent {
  id          String   @id @default(cuid())
  leadId      String
  contactId   String
  channel     String
  direction   String
  content     String
  metadata    Json?
  timestamp   DateTime @default(now())

  @@index([leadId])
  @@index([timestamp])
}

model AgentEvent {
  id             String   @id @default(cuid())
  type           String
  payload        Json
  source         String
  correlationId  String?
  timestamp      DateTime @default(now())

  @@index([type])
  @@index([timestamp])
}

model Outcome {
  id          String   @id @default(cuid())
  leadId      String
  type        String
  value       Json
  attributedTo String
  timestamp   DateTime @default(now())

  @@index([leadId])
  @@index([type])
}

// ---------------------------------------------------------------------------
// CRE DOMAIN MODELS
// ---------------------------------------------------------------------------

model Property {
  id              String    @id @default(cuid())
  name            String?
  address         String
  city            String
  state           String
  zip             String
  propertyType    String    // Office, Retail, Industrial, Multifamily
  sizeSqFt        Int?
  yearBuilt       Int?
  class           String?   // Class A, Class B, Class C
  ownerId         String?   // Could link to a Contact or separate Owner model
  metadata        Json?
  listings        Listing[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([propertyType])
  @@index([state, city])
}

model Listing {
  id              String    @id @default(cuid())
  propertyId      String
  property        Property  @relation(fields: [propertyId], references: [id])
  brokerId        String?
  broker          Broker?   @relation(fields: [brokerId], references: [id])
  type            String    // For Sale, For Lease
  askingPrice     Float?
  pricePerSqFt    Float?
  leaseType       String?   // NNN, Gross, Modified Gross
  capRate         Float?
  status          String    @default("active")
  description     String?
  availableSqFt   Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([propertyId])
  @@index([status])
  @@index([type])
}

model Broker {
  id              String    @id @default(cuid())
  contactId       String    @unique
  contact         Contact   @relation(fields: [contactId], references: [id])
  firmName        String?
  licenseNumber   String?
  specialization  String?   // Tenant Rep, Landlord Rep, Investment Sales
  tier            String?   // e.g. "boutique", "national"
  listings        Listing[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model TenantApplication {
  id              String    @id @default(cuid())
  leadId          String    @unique
  lead            Lead      @relation(fields: [leadId], references: [id])
  businessName    String?
  industry        String?
  yearsInBusiness Int?
  annualRevenue   Float?
  creditScore     Int?
  status          String    @default("pending") // pending, approved, rejected, loi_submitted
  notes           String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
}