# Database
DATABASE_URL=postgresql://agentive:agentive_dev@localhost:5432/agentive

# Redis
REDIS_URL=redis://localhost:6379

# LLM (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# Retell AI
RETELL_API_KEY=key_...
RETELL_AGENT_ID=                    # Speed-to-Lead outbound call agent
RETELL_DEMO_AGENT_ID=               # Sarah web demo agent (from Retell dashboard)
SPECIALIST_PHONE_NUMBER=+1...

# Cal.com Booking (for demo scheduling)
CAL_BOOKING_URL=https://cal.com/saiful-agentive/demo

# VAPI (Alternative voice provider for Sarah demo)
VAPI_API_KEY=                          # Server API key from dashboard.vapi.ai
VAPI_PUBLIC_KEY=                       # Public key for browser SDK (starts with pk-)
VAPI_ASSISTANT_ID=                     # Assistant ID for Sarah (starts with asst-)

# Twilio (API Key auth)
TWILIO_ACCOUNT_SID=AC...
TWILIO_API_KEY_SID=SK...
TWILIO_API_KEY_SECRET=...
TWILIO_PHONE_NUMBER=+1...

# Calendar (Cal.com)
CAL_API_KEY=cal_live_...
CAL_EVENT_TYPE_ID=5413213

# App
PORT=3001
NODE_ENV=development
SLA_RESPONSE_SECONDS=300