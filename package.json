{
  "name": "agentive-platform",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "db:push": "prisma db push --schema=packages/engine/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=packages/engine/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=packages/engine/prisma/schema.prisma"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "prisma": "^6.19.3",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
